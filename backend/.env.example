# ============================================================
# AnyMentor Backend - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Server ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173
PLATFORM_NAME=AnyMentor
PLATFORM_DOMAIN=anymentor.com

# ─── Database (PostgreSQL) ────────────────────────────────────
# For Docker: postgresql://anymentor:anymentor_pass_dev@postgres:5432/anymentor_db
# For local:  postgresql://postgres:password@localhost:5432/anymentor_db
DATABASE_URL=postgresql://anymentor:anymentor_pass_dev@localhost:5432/anymentor_db

# ─── JWT Authentication ───────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-characters-long
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters-long
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Email (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
# For Gmail: use App Password (not regular password)
# Go to: Google Account > Security > 2-Step Verification > App passwords
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=AnyMentor <noreply@anymentor.com>

# ─── Razorpay (India - Primary Gateway) ──────────────────────
# Supports: UPI, Google Pay, PhonePe, Cards, Netbanking, Wallets
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── PhonePe (Direct Integration) ────────────────────────────
# Get from: https://business.phonepe.com
PHONEPE_MERCHANT_ID=MERCHANTUAT
PHONEPE_SALT_KEY=099eb0cd-02cf-4e2a-8aca-3e6c6aff0399
PHONEPE_SALT_INDEX=1
PHONEPE_ENV=sandbox
# sandbox: https://api-preprod.phonepe.com/apis/pg-sandbox
# production: https://api.phonepe.com/apis/hermes

# ─── Stripe (International Payments) ─────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ─── File Upload ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
# Allowed MIME types (comma separated)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,image/gif,application/pdf,video/mp4,video/webm

# ─── AWS S3 (Optional - for cloud file storage) ───────────────
# If not set, files will be stored locally in UPLOAD_DIR
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=anymentor-uploads
AWS_REGION=ap-south-1
AWS_S3_URL=https://anymentor-uploads.s3.ap-south-1.amazonaws.com

# ─── Redis (Optional - for rate limiting & caching) ──────────
# If not set, in-memory caching will be used
REDIS_URL=redis://localhost:6379
# For production with password:
# REDIS_URL=redis://:password@localhost:6379

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=5

# ─── Security ─────────────────────────────────────────────────
# CORS - comma separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Session secret for CSRF
SESSION_SECRET=your-session-secret-for-csrf

# ─── Owner Account (Created during seed) ──────────────────────
OWNER_EMAIL=owner@anymentor.com
OWNER_PASSWORD=SuperSecureOwnerPass123!
OWNER_FIRST_NAME=Platform
OWNER_LAST_NAME=Owner
