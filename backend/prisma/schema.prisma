generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────

enum Role {
  OWNER
  COMPANY_ADMIN
  MANAGER
  USER
}

enum PlanName {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  UNPAID
}

enum PaymentGateway {
  RAZORPAY
  PHONEPE
  STRIPE
  UPI
  MANUAL
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  TASK
  DEMO
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
  ASSIGNMENT
  LIVE_SESSION
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
  SUSPENDED
}

// ─── Core Models ──────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  passwordHash         String
  role                 Role      @default(USER)
  companyId            String?
  firstName            String
  lastName             String
  avatar               String?
  phone                String?
  isActive             Boolean   @default(true)
  emailVerified        Boolean   @default(false)
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  company              Company?   @relation("CompanyUsers", fields: [companyId], references: [id])
  ownedCompanies       Company[]  @relation("CompanyOwner")
  refreshTokens        RefreshToken[]
  enrollments          Enrollment[]
  lessonProgress       LessonProgress[]
  orders               Order[]
  assignedLeads        Lead[]     @relation("AssignedLeads")
  createdLeads         Lead[]     @relation("CreatedLeads")
  assignedDeals        Deal[]
  activities           Activity[]
  assignedTickets      Ticket[]   @relation("AssignedTickets")
  createdTickets       Ticket[]   @relation("CreatedTickets")
  ticketMessages       TicketMessage[]
  auditLogs            AuditLog[]
  courseInstructor     Course[]   @relation("CourseInstructor")

  @@index([email])
  @@index([companyId])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  isRevoked Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Company {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  description  String?
  ownerId      String
  logo         String?
  favicon      String?
  primaryColor String   @default("#1a3c6e")
  secondaryColor String @default("#d4a017")
  accentColor  String   @default("#800020")
  bgColor      String   @default("#f5f0e8")
  fontHeading  String   @default("Cormorant Garamond")
  fontBody     String   @default("Rajdhani")
  customDomain String?  @unique
  address      Json?
  phone        String?
  email        String?
  website      String?
  socialLinks  Json?
  // Feature toggles
  hasLms       Boolean  @default(true)
  hasEcommerce Boolean  @default(true)
  hasCrm       Boolean  @default(true)
  hasAnalytics Boolean  @default(true)
  hasSupport   Boolean  @default(true)
  // Settings
  settings     Json     @default("{}")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  owner        User     @relation("CompanyOwner", fields: [ownerId], references: [id])
  users        User[]   @relation("CompanyUsers")
  subscription Subscription?
  courses      Course[]
  products     Product[]
  categories   Category[]
  orders       Order[]
  leads        Lead[]
  contacts     Contact[]
  deals        Deal[]
  activities   Activity[]
  tickets      Ticket[]
  knowledgeBase KnowledgeBase[]
  auditLogs    AuditLog[]

  @@index([slug])
  @@index([ownerId])
  @@index([isActive])
  @@map("companies")
}

// ─── Billing Models ───────────────────────────────────────────

model Plan {
  id              String       @id @default(uuid())
  name            PlanName     @unique
  displayName     String
  description     String?
  monthlyPrice    Float        @default(0)
  yearlyPrice     Float        @default(0)
  currency        String       @default("INR")
  maxUsers        Int          @default(5)
  maxCourses      Int          @default(3)
  maxProducts     Int          @default(10)
  maxStorageGb    Float        @default(1)
  hasCustomDomain Boolean      @default(false)
  hasAnalytics    Boolean      @default(false)
  hasApiAccess    Boolean      @default(false)
  hasPrioritySupport Boolean   @default(false)
  features        String[]     @default([])
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  subscriptions   Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String             @id @default(uuid())
  companyId              String             @unique
  planId                 String
  status                 SubscriptionStatus @default(TRIALING)
  billingCycle           BillingCycle       @default(MONTHLY)
  currentPeriodStart     DateTime
  currentPeriodEnd       DateTime
  trialEndsAt            DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?
  paymentGateway         PaymentGateway?
  externalSubscriptionId String?
  externalCustomerId     String?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     Plan     @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([companyId])
  @@index([status])
  @@map("subscriptions")
}

model Payment {
  id              String         @id @default(uuid())
  subscriptionId  String?
  companyId       String?
  orderId         String?
  amount          Float
  currency        String         @default("INR")
  status          PaymentStatus  @default(PENDING)
  gateway         PaymentGateway
  gatewayOrderId  String?
  gatewayPaymentId String?
  gatewaySignature String?
  description     String?
  metadata        Json?
  refundedAmount  Float?
  refundReason    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  order        Order?        @relation(fields: [orderId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([gatewayPaymentId])
  @@map("payments")
}

// ─── LMS Models ───────────────────────────────────────────────

model Course {
  id           String      @id @default(uuid())
  companyId    String
  title        String
  slug         String
  description  String?
  thumbnail    String?
  instructorId String?
  price        Float       @default(0)
  comparePrice Float?
  currency     String      @default("INR")
  isFree       Boolean     @default(false)
  isPublished  Boolean     @default(false)
  category     String?
  tags         String[]    @default([])
  level        CourseLevel @default(ALL_LEVELS)
  language     String      @default("Hindi")
  totalDuration Int        @default(0)
  totalLessons  Int        @default(0)
  requirements  String[]   @default([])
  whatYouLearn  String[]   @default([])
  certificate   Boolean    @default(false)
  rating        Float       @default(0)
  totalRatings  Int         @default(0)
  totalStudents Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  instructor User?       @relation("CourseInstructor", fields: [instructorId], references: [id])
  modules    CourseModule[]
  enrollments Enrollment[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([isPublished])
  @@map("courses")
}

model CourseModule {
  id          String   @id @default(uuid())
  courseId    String
  companyId   String
  title       String
  description String?
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
  @@index([companyId])
  @@map("course_modules")
}

model Lesson {
  id          String     @id @default(uuid())
  moduleId    String
  courseId    String
  companyId   String
  title       String
  type        LessonType @default(TEXT)
  content     String?
  videoUrl    String?
  videoProvider String?
  duration    Int        @default(0)
  order       Int        @default(0)
  isPublished Boolean    @default(false)
  isFreePreview Boolean  @default(false)
  attachments String[]   @default([])
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  module   CourseModule    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([moduleId])
  @@index([courseId])
  @@index([companyId])
  @@map("lessons")
}

model Enrollment {
  id            String           @id @default(uuid())
  userId        String
  courseId      String
  companyId     String
  status        EnrollmentStatus @default(ACTIVE)
  progress      Float            @default(0)
  completedAt   DateTime?
  certificateUrl String?
  paymentId     String?
  enrolledAt    DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([companyId])
  @@map("enrollments")
}

model LessonProgress {
  id             String   @id @default(uuid())
  userId         String
  lessonId       String
  courseId       String
  companyId      String
  completed      Boolean  @default(false)
  watchedSeconds Int      @default(0)
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId, courseId])
  @@index([companyId])
  @@map("lesson_progress")
}

// ─── E-commerce Models ────────────────────────────────────────

model Category {
  id        String    @id @default(uuid())
  companyId String
  name      String
  slug      String
  parentId  String?
  image     String?
  isActive  Boolean   @default(true)
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("categories")
}

model Product {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  slug         String
  description  String?
  sku          String?
  price        Float
  comparePrice Float?
  currency     String   @default("INR")
  categoryId   String?
  images       String[] @default([])
  stock        Int      @default(0)
  lowStockAlert Int     @default(5)
  isActive     Boolean  @default(true)
  isDigital    Boolean  @default(false)
  digitalFile  String?
  weight       Float?
  tags         String[] @default([])
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id])
  orderItems OrderItem[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([isActive])
  @@map("products")
}

model Cart {
  id        String     @id @default(uuid())
  userId    String
  companyId String
  items     Json       @default("[]")
  couponCode String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("carts")
}

model Order {
  id              String        @id @default(uuid())
  companyId       String
  userId          String
  orderNumber     String        @unique
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentGateway  PaymentGateway?
  subtotal        Float
  tax             Float         @default(0)
  discount        Float         @default(0)
  shippingCost    Float         @default(0)
  total           Float
  currency        String        @default("INR")
  shippingAddress Json?
  billingAddress  Json?
  notes           String?
  couponCode      String?
  trackingNumber  String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  canceledAt      DateTime?
  cancelReason    String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  company  Company     @relation(fields: [companyId], references: [id])
  user     User        @relation(fields: [userId], references: [id])
  items    OrderItem[]
  payments Payment[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id         String  @id @default(uuid())
  orderId    String
  productId  String?
  courseId   String?
  name       String
  sku        String?
  price      Float
  quantity   Int     @default(1)
  total      Float
  image      String?
  metadata   Json?

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

// ─── CRM Models ───────────────────────────────────────────────

model Lead {
  id           String     @id @default(uuid())
  companyId    String
  firstName    String
  lastName     String?
  email        String?
  phone        String?
  company      String?
  designation  String?
  source       String?
  status       LeadStatus @default(NEW)
  assignedToId String?
  createdById  String?
  value        Float?
  currency     String     @default("INR")
  notes        String?
  tags         String[]   @default([])
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  lastContactedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  companyRef Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo User?      @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdBy  User?      @relation("CreatedLeads", fields: [createdById], references: [id])
  contacts   Contact[]
  deals      Deal[]
  activities Activity[]

  @@index([companyId])
  @@index([status])
  @@index([assignedToId])
  @@map("leads")
}

model Contact {
  id          String   @id @default(uuid())
  companyId   String
  leadId      String?
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  company     String?
  designation String?
  address     Json?
  notes       String?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyRef Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead?   @relation(fields: [leadId], references: [id])

  @@index([companyId])
  @@index([leadId])
  @@map("contacts")
}

model Deal {
  id                String   @id @default(uuid())
  companyId         String
  leadId            String?
  title             String
  value             Float    @default(0)
  currency          String   @default("INR")
  stage             String   @default("prospect")
  probability       Float    @default(0)
  expectedCloseDate DateTime?
  actualCloseDate   DateTime?
  assignedToId      String?
  notes             String?
  isWon             Boolean?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead       Lead?   @relation(fields: [leadId], references: [id])
  assignedTo User?   @relation(fields: [assignedToId], references: [id])
  activities Activity[]

  @@index([companyId])
  @@index([stage])
  @@map("deals")
}

model Activity {
  id          String       @id @default(uuid())
  companyId   String
  leadId      String?
  dealId      String?
  userId      String
  type        ActivityType
  description String
  outcome     String?
  scheduledAt DateTime?
  completedAt DateTime?
  duration    Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead      Lead?    @relation(fields: [leadId], references: [id])
  deal      Deal?    @relation(fields: [dealId], references: [id])
  createdBy User     @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([leadId])
  @@index([userId])
  @@map("activities")
}

// ─── Support Models ───────────────────────────────────────────

model Ticket {
  id           String         @id @default(uuid())
  companyId    String
  userId       String
  assignedToId String?
  subject      String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     String?
  tags         String[]       @default([])
  resolvedAt   DateTime?
  closedAt     DateTime?
  satisfactionRating Int?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  company    Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User            @relation("CreatedTickets", fields: [userId], references: [id])
  assignedTo User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  messages   TicketMessage[]

  @@index([companyId])
  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id          String   @id @default(uuid())
  ticketId    String
  companyId   String
  userId      String
  message     String
  isInternal  Boolean  @default(false)
  attachments String[] @default([])
  createdAt   DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([ticketId])
  @@map("ticket_messages")
}

model KnowledgeBase {
  id          String   @id @default(uuid())
  companyId   String
  title       String
  slug        String
  content     String
  category    String?
  tags        String[] @default([])
  isPublished Boolean  @default(false)
  views       Int      @default(0)
  helpful     Int      @default(0)
  notHelpful  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([isPublished])
  @@map("knowledge_base")
}

// ─── Audit Log ────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  companyId  String?
  userId     String?
  action     String
  resource   String
  resourceId String?
  changes    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id])
  user    User?    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}
